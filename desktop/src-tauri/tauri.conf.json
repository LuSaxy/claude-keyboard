{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clawd Control",
  "version": "0.1.0",
  "identifier": "ai.clawd.control",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clawd Control",
        "width": 780,
        "height": 920,
        "minWidth": 420,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
